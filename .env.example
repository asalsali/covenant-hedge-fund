# Market Data
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Crypto Data (CoinGecko free demo tier)
# Sign up at https://www.coingecko.com/en/api/pricing (free plan)
# Without this key, crypto analysis falls back to price-only via yfinance
COINGECKO_API_KEY=

# Ollama (optional -- auto-detected at localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
#
# Model selection (optional -- auto-detects best pulled model):
# OLLAMA_MODEL=qwen2.5:7b-instruct
#
# Recommended models by VRAM tier:
#   Tier 1 (8GB  VRAM): qwen2.5:7b-instruct   ~4.7 GB  (default)
#   Tier 2 (16GB VRAM): phi4:14b               ~9   GB
#   Tier 3 (24GB VRAM): qwen2.5:32b-instruct   ~20  GB
#   Tier 4 (48GB VRAM): llama3.3:70b-instruct  ~42  GB
#
# If OLLAMA_MODEL is not set, the system auto-selects the best model
# already pulled in Ollama. Use --model CLI flag for per-run override.
